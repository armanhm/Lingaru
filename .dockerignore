# Keep the nginx multi-stage build context small and reproducible.
**/node_modules
**/__pycache__
**/.pytest_cache
**/dist
**/build
**/.venv
**/venv
**/.git
**/.env
**/.env.*
**/db.sqlite3
**/.DS_Store
# Only Django's runtime upload/static dirs, NOT apps named `media`
# (e.g. backend/apps/media/ which is a Django app).
backend/staticfiles
backend/media
docs/
