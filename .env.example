# .env.example
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=lingaru
DB_USER=lingaru
DB_PASSWORD=lingaru
DB_HOST=postgres
DB_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Sentry (leave empty in dev/local; set on production) ──────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=  # optional; set to git SHA in CI/CD if you want releases

# ── Chat-memory kill switch ───────────────────────────────────────
# When false (default), /api/memory/notes/ REST + Settings → Memory tab
# still work; ChatView just doesn't inject learner context into the
# system prompt or auto-extract notes from "remember X" turns. Flip to
# true once you trust the extractor in your deployment.
LINGARU_MEMORY_ENABLED=false
